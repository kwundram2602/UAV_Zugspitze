%% Background image.
\newcommand{\setBackgroundImage}[1]{
\begin{tikzpicture}[remember picture,overlay]
  \tikzset{inner sep=0pt,outer sep=0pt}
    %% Centered on page.
    \node at (current page.center) {
      \includegraphics[height=\paperheight]{#1} %% Figure with full paper height.
    };
\end{tikzpicture}
}
\let\imgfundo\setBackgroundImage

%% Poster header built with TikZ.
\newdimen\altura
\altura=13cm
\newdimen\headerRightWhitePanelWidth
\headerRightWhitePanelWidth=14.4cm
\newdimen\headerBlueWhiteGap
\headerBlueWhiteGap=3cm
\newcommand{\posterHeader}[3]{
\begin{tikzpicture}[remember picture,overlay]
\node at (current page.north west){
  \begin{tikzpicture}[remember picture,overlay]
  \draw[fill=#3] (-3cm,0) rectangle (\dimexpr\paperwidth-\headerRightWhitePanelWidth-\headerBlueWhiteGap\relax,-\altura);
      \node[right] at (1.5cm,-.60*\altura) {
	\includegraphics[height=8cm]{#1} %% first logo
      };
  \end{tikzpicture}
};
\node at (current page.north east){
  \begin{tikzpicture}[remember picture,overlay]
  \filldraw[PosterWhite] (-\headerRightWhitePanelWidth,0) rectangle (0,-1.01*\altura);
      \node[left] at (-2.9cm,-.61*\altura) {
	\includegraphics[height=7cm,width=13cm]{#2} %% second logo
      };
      %\filldraw[laranja](-15.5cm,0) rectangle (-14.4cm,-\altura);
      
  \end{tikzpicture}
};
\node at (current page.north){
  \begin{tikzpicture}[remember picture,overlay,node distance=2mm]
    \node[PosterWhite] (n1) at (-1.5,-4) {\shortstack{\Large\textbf{\posterTitle}}};
    \node[PosterWhite] (n2) [below = of n1] {\shortstack{\Large\textbf{\posterSubtitle}}};
    \node[PosterWhite] (n3) [below = of n2] {\authorNames};
    \node[PosterWhite] (n4) [below = of n3] {\small{\institutionName}};
  \end{tikzpicture}
};
\end{tikzpicture}
}
\let\titulo\posterHeader

%% Conference banner built with TikZ.
\newcommand{\conferenceBanner}[1]{
\begin{tikzpicture}[remember picture,overlay]
\node at (current page.north){
  \begin{tikzpicture}[remember picture,overlay]
     \draw[fill=#1] (-.5*\textwidth-2cm,-13.25) rectangle (.5*\textwidth-2cm,-14.75);
    \node[PosterWhite] at (-2cm,-14) {\Large{
	\nomecongresso \qquad --- \qquad \textbf{\abrev}
      }};
  \end{tikzpicture}
};
\end{tikzpicture}
}
\let\congresso\conferenceBanner

%% Footer built with TikZ.
\newcommand{\posterFooter}[3]{
\begin{tikzpicture}[remember picture,overlay]
\node at (current page.south west){
  \begin{tikzpicture}[remember picture,overlay,inner sep=0,outer sep=0]
      \draw[fill=#3] (0,0) rectangle (\paperwidth,5);
      \node[above right] at (4cm,1) {
	\includegraphics[height=3cm]{#1} %% third logo
      };
  \end{tikzpicture}
};
\node[yshift=2cm,yellow] at (current page.south){\url{http://latexbr.blogspot.com}};
\node at (current page.south east){
  \begin{tikzpicture}[remember picture,overlay,inner sep=0,outer sep=0]
      \node[above left] at (-4cm,1) {
	\includegraphics[height=3cm]{#2} %% fourth logo
      };
  \end{tikzpicture}
};
\end{tikzpicture}
}
\let\rodape\posterFooter